# ColdChain AI — ortam değişkenleri
# Bu dosyayı ".env" olarak kopyalayıp kendi değerlerinizi girin.

# Google Gemini API anahtarı (zorunlu) — https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Kullanılacak model (opsiyonel)
GEMINI_MODEL=gemini-1.5-flash

# Sunucu portu (opsiyonel)
PORT=3000

# Fiyat/kur override (opsiyonel) — boş bırakılırsa model tablosundan alınır
# PRICE_INPUT_PER_M=0.10
# PRICE_OUTPUT_PER_M=0.40
# USD_TRY_RATE=39
