{
  "name": "coldchain-ai",
  "version": "2.0.0",
  "description": "ColdChain AI — Soğuk Zincir İade Otomasyon Sistemi",
  "main": "main.js",
  "scripts": {
    "start": "node --use-system-ca server.js",
    "app": "electron .",
    "build": "electron-builder",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "canvas": "^3.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.hukudok.coldchain",
    "productName": "Soguk Zincir Otomasyon",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
